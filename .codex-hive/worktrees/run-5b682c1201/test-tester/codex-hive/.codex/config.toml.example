[project]
name = "codex-hive"
instructions_files = ["AGENTS.md", "docs/architecture.md", "docs/safety.md"]

[agents]
directory = ".codex/agents"

[profiles.default]
model = "gpt-5.4"
model_reasoning_effort = "high"
sandbox_mode = "workspace-write"

[profiles.readonly-review]
model = "gpt-5.4"
model_reasoning_effort = "high"
sandbox_mode = "read-only"

[commands]
team_mode = "python .codex/skills/team-mode/scripts/launch_team.py"
